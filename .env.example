# Palworld REST API (Basic auth: admin + AdminPassword)
PALWORLD_API_URL=http://host.docker.internal:8212
PALWORLD_API_USER=admin
PALWORLD_API_PASSWORD=changeme

# Paths inside the container (mount Unraid appdata here)
PALWORLD_LOG_PATH=/data/logs
PALWORLD_CONFIG_PATH=/data/PalWorldSettings.ini

# Dashboard
DASHBOARD_PORT=8787
# Optional: require this token for announce/save (Bearer or X-Dashboard-Token)
DASHBOARD_TOKEN=
POLL_INTERVAL_MS=2000
LOG_BUFFER_LINES=500
