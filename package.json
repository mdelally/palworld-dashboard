{
  "name": "palworld-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.js",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/index.js",
    "preview": "npm run build && npm start"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.57",
    "@nuxt/ui": "4.10.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "vue-tsc": "^2.2.12"
  }
}
